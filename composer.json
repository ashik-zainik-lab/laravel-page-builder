{
    "name": "coderstm/laravel-page-builder",
    "description": "A section-based page builder for Laravel using layouts and JSON rendering.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dipak Sarkar",
            "email": "hello@dipaksarkar.in"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "qirolab/laravel-themer": "^2.4",
        "spatie/laravel-sluggable": "^3.6"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Coderstm\\PageBuilder\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Coderstm\\PageBuilder\\Tests\\": "tests/",
            "Coderstm\\PageBuilder\\Tests\\Stubs\\": "tests/Stubs/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Coderstm\\PageBuilder\\Providers\\PageBuilderServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ]
    }
}
